@using SportShop.ViewModels.User
@model AddressViewModel

@{
    ViewData["Title"] = "Thêm địa chỉ mới";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <h4 class="fw-bold border-bottom pb-3 mb-4">THÊM ĐỊA CHỈ MỚI</h4>

                    <form asp-action="Create" method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên người nhận</label>
                                <input asp-for="ReceiverName" class="form-control" placeholder="Họ và tên" />
                                <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại liên hệ" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tỉnh / Thành phố</label>
                                <!-- Dropdown này sẽ được JS đổ dữ liệu -->
                                <select asp-for="Province" class="form-select" id="provinceSelect">
                                    <option value="">-- Đang tải danh sách... --</option>
                                </select>
                                <span asp-validation-for="Province" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label fw-bold">Quận/Huyện, Xã/Phường</label>
                                <!-- Dropdown này sẽ thay đổi dựa theo Tỉnh -->
                                <select asp-for="Commune" class="form-select" id="communeSelect" disabled>
                                    <option value="">-- Vui lòng chọn Tỉnh/Thành trước --</option>
                                </select>
                                <span asp-validation-for="Commune" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ cụ thể</label>
                            <textarea asp-for="SpecificAddress" class="form-control" rows="2" placeholder="Số nhà, tên đường, tòa nhà..."></textarea>
                            <span asp-validation-for="SpecificAddress" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4 mt-3">
                            <input asp-for="IsDefault" class="form-check-input" type="checkbox" id="flexCheckDefault">
                            <label class="form-check-label text-danger fw-bold" for="flexCheckDefault">
                                Đặt làm địa chỉ mặc định
                            </label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-sport px-4">Lưu Địa Chỉ</button>
                            <a asp-action="Index" class="btn btn-light border px-4">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        <!-- Gọi API xử lý thả xuống Tỉnh/Xã -->
        <script src="~/js/address-api.js" asp-append-version="true"></script>
    }
}