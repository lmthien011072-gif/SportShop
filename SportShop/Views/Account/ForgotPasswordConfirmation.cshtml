@{
    ViewData["Title"] = "Gửi yêu cầu thành công";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <span class="bg-light text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <h1 class="m-0">📧</h1>
                        </span>
                    </div>
                    <h2 class="fw-bold mb-3">Kiểm tra email của bạn</h2>
                    <p class="text-muted mb-4">
                        Chúng tôi đã gửi một liên kết đặt lại mật khẩu tới email của bạn. Vui lòng kiểm tra hộp thư đến (hoặc thư mục Spam).
                    </p>

                    <!-- MẸO DEV: Hiển thị link reset tạm thời khi chưa tích hợp gửi Email thực tế -->
                    @if (TempData["TestResetLink"] != null)
                    {
                        <div class="alert alert-warning text-break text-start mb-4">
                            <strong>[Chỉ dành cho Dev]</strong> Click vào link này để test Đặt lại mật khẩu ngay: <br />
                            <a href="@TempData["TestResetLink"]" class="fw-bold text-danger">@TempData["TestResetLink"]</a>
                        </div>
                    }

                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Về Trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>