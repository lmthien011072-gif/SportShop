@model SportShop.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">QUÊN MẬT KHẨU?</h2>
                        <p class="text-muted">Nhập email của bạn, chúng tôi sẽ gửi liên kết để đặt lại mật khẩu.</p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Email đăng ký</label>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="VD: email@domain.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-sport btn-lg w-100 fw-bold mb-3">GỬI YÊU CẦU</button>
                    </form>

                    <div class="text-center mt-2">
                        <a asp-action="Login" class="text-secondary text-decoration-none"><i class="fas fa-arrow-left"></i> Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}