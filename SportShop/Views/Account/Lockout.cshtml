@{
    ViewData["Title"] = "Tài khoản bị khóa";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm border-0 border-danger">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <span class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <h1 class="m-0">🔒</h1>
                        </span>
                    </div>
                    <h2 class="fw-bold text-danger mb-3">TÀI KHOẢN BỊ KHÓA</h2>
                    <p class="text-dark mb-4">
                        Tài khoản này đã bị tạm khóa do nhập sai mật khẩu quá nhiều lần. <br />
                        Vui lòng thử lại sau một vài phút hoặc sử dụng tính năng <strong>Quên mật khẩu</strong>.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="ForgotPassword" class="btn btn-outline-danger fw-bold">QUÊN MẬT KHẨU</a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">VỀ TRANG CHỦ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>