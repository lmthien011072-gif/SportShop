@using SportShop.ViewModels.Product
@model ProductDetailViewModel

@{
    ViewData["Title"] = Model.Name;

    // Bóc tách danh sách Màu và Size duy nhất từ danh sách Biến thể (Chỉ lấy các biến thể còn hàng để hiển thị nếu muốn, ở đây lấy tất cả)
    var distinctColors = Model.AvailableVariants.Select(v => v.Color).Distinct().ToList();
    var distinctSizes = Model.AvailableVariants.Select(v => v.Size).Distinct().ToList();
}

<!-- Nhúng file CSS độc lập dành riêng cho trang Chi tiết sản phẩm -->
<link rel="stylesheet" href="~/css/product-details.css" asp-append-version="true" />

<div class="container mt-4 mb-5">
    <!-- BREADCRUMB -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark">Trang chủ</a></li>

            <!-- CẬP NHẬT: Trỏ về Catalog thay vì Category -->
            <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-decoration-none text-dark">@Model.CategoryName</a></li>

            @if (!string.IsNullOrEmpty(Model.SportName))
            {
                <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-sportId="@Model.SportId" class="text-decoration-none text-dark">@Model.SportName</a></li>
            }

            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <!-- CHI TIẾT SẢN PHẨM CHÍNH -->
    <div class="row bg-white p-4 rounded-4 shadow-sm">
        <!-- Cột Trái: Hình ảnh -->
        <div class="col-md-5">
            <div class="border rounded-4 p-2 mb-3 text-center bg-light">
                <img src="@Model.MainImageUrl" alt="@Model.Name" class="img-fluid rounded-3" id="mainImage" style="max-height: 450px; object-fit: contain;" />
            </div>

            @if (Model.GalleryImages.Any())
            {
                <div class="d-flex gap-2 overflow-auto pb-2">
                    <img src="@Model.MainImageUrl" class="img-thumbnail cursor-pointer border-accent rounded-3" style="width: 80px; height: 80px; object-fit: cover;" onclick="changeMainImage(this.src)" />
                    @foreach (var imgUrl in Model.GalleryImages)
                    {
                        <img src="@imgUrl" class="img-thumbnail cursor-pointer rounded-3" style="width: 80px; height: 80px; object-fit: cover;" onclick="changeMainImage(this.src)" />
                    }
                </div>
            }
        </div>

        <!-- Cột Phải: Thông tin & Đặt hàng -->
        <div class="col-md-7 ps-md-5 mt-4 mt-md-0">
            <!-- CẬP NHẬT: Nhãn thương hiệu trỏ về Catalog thay vì Brand -->
            <a asp-controller="Catalog" asp-action="Index" asp-route-brandId="@Model.BrandId" class="badge bg-primary-theme mb-2 text-decoration-none px-3 py-2 rounded-pill">@Model.BrandName</a>

            <h1 class="h3 fw-bold mb-3 text-dark">@Model.Name</h1>
            <h2 class="text-accent fw-bold mb-4 display-6" style="font-size: 2rem;">@Model.Price.ToString("N0") ₫</h2>

            <form asp-controller="Cart" asp-action="AddToCart" method="post" id="addToCartForm">
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                <!-- Input ẩn chứa mã biến thể cuối cùng sau khi user chọn xong cả Size và Màu -->
                <input type="hidden" name="variantId" id="selectedVariantId" required />

                @if (Model.AvailableVariants.Any())
                {
                    <!-- Khu vực 1: Chọn Màu Sắc -->
                    <div class="mb-3">
                        <label class="fw-bold mb-2 text-secondary">Màu sắc:</label>
                        <div class="d-flex flex-wrap gap-2" id="colorSelection">
                            @foreach (var color in distinctColors)
                            {
                                <button type="button" class="btn variant-btn color-btn" data-color="@color">@color</button>
                            }
                        </div>
                    </div>

                    <!-- Khu vực 2: Chọn Size -->
                    <div class="mb-3">
                        <label class="fw-bold mb-2 text-secondary">Kích thước (Size):</label>
                        <div class="d-flex flex-wrap gap-2" id="sizeSelection">
                            @foreach (var size in distinctSizes)
                            {
                                <button type="button" class="btn variant-btn size-btn" data-size="@size">@size</button>
                            }
                        </div>
                    </div>

                    <!-- Thông báo trạng thái kho hàng -->
                    <div class="mb-4 bg-light p-3 rounded-3 border">
                        <span id="stockStatus" class="text-muted fw-bold"><i class="fas fa-info-circle me-1 text-primary"></i> Vui lòng chọn màu sắc và kích thước để xem tình trạng kho.</span>
                    </div>

                    <div class="d-flex gap-3 align-items-center mb-4">
                        <div style="width: 130px;">
                            <label class="fw-bold mb-2 text-secondary fs-6">Số lượng:</label>
                            <div class="input-group">
                                <input type="number" name="quantity" class="form-control text-center fw-bold rounded-3" value="1" min="1" max="10" id="quantityInput" required />
                            </div>
                        </div>
                        <div class="flex-grow-1 pt-4">
                            <button type="submit" class="btn btn-sport btn-lg w-100 py-3 text-uppercase fw-bold rounded-pill shadow-sm btn-prevent-double" id="btnAddToCart" disabled>
                                <i class="fas fa-cart-plus me-2"></i> Thêm Vào Giỏ Hàng
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger fw-bold rounded-4 shadow-sm" role="alert">
                        <i class="fas fa-box-open me-2"></i> Sản phẩm này hiện đang tạm hết hàng!
                    </div>
                    <button type="button" class="btn btn-secondary btn-lg w-100 py-3 text-uppercase fw-bold rounded-pill" disabled>Tạm Hết Hàng</button>
                }
            </form>

            <hr class="my-5" />

            <!-- Mô Tả Sản Phẩm -->
            <div>
                <h5 class="fw-bold mb-4 text-primary-theme text-uppercase border-bottom pb-2">Mô Tả Sản Phẩm</h5>
                <div class="text-muted" style="line-height: 1.8; font-size: 0.95rem;">
                    @(string.IsNullOrEmpty(Model.Description) ? Html.Raw("<p>Chưa có mô tả chi tiết cho sản phẩm này.</p>") : Html.Raw(Model.Description))
                </div>
            </div>
        </div>
    </div>

    <!-- KHỐI SẢN PHẨM LIÊN QUAN -->
    @if (Model.RelatedProducts != null && Model.RelatedProducts.Any())
    {
        <div class="mt-5 pt-4">
            <h4 class="fw-bold mb-4 text-primary-theme text-uppercase">Sản Phẩm Cùng Danh Mục</h4>
            <div class="row row-cols-2 row-cols-md-4 g-4">
                @foreach (var item in Model.RelatedProducts)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 rounded-4 product-card">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                <img src="@item.ThumbnailUrl" class="card-img-top p-3 rounded-top-4" alt="@item.Name" style="height: 200px; object-fit: contain;">
                            </a>
                            <div class="card-body d-flex flex-column">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                    <h6 class="card-title fw-bold text-truncate-2">@item.Name</h6>
                                </a>
                                <p class="card-text text-accent fw-bold mt-auto fs-5">@item.Price.ToString("N0") ₫</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <!-- CHUYỂN DỮ LIỆU C# SANG JAVASCRIPT -->
    <script>
        const productVariants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableVariants));
    </script>

    <!-- GỌI SCRIPT XỬ LÝ CỤC BỘ CHO TRANG SẢN PHẨM -->
    <script src="~/js/product-details.js" asp-append-version="true"></script>
}