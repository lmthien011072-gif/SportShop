@model SportShop.ViewModels.Home.HomeViewModel

@{
    ViewData["Title"] = "Hệ thống thể thao chính hãng";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-lg-3 d-none d-lg-block">
            <!-- GỌI VIEW COMPONENT ĐỂ RENDER MENU -->
            @await Component.InvokeAsync("MegaMenu")
        </div>

        <div class="col-lg-9">
            <div id="mainBanner" class="carousel slide shadow-sm rounded overflow-hidden h-100" data-bs-ride="carousel">
                <div class="carousel-inner h-100">
                    <div class="carousel-item active h-100">
                        <img src="https://placehold.co/900x400/1a1a2e/ffffff?text=XU+HUONG+THE+THAO+2026" class="d-block w-100 h-100" style="object-fit: cover;" alt="Banner 1">
                    </div>
                    <div class="carousel-item h-100">
                        <img src="https://placehold.co/900x400/e94560/ffffff?text=SALE+UPTO+50%25" class="d-block w-100 h-100" style="object-fit: cover;" alt="Banner 2">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#mainBanner" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#mainBanner" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <!-- KHỐI 1: SẢN PHẨM NỔI BẬT (ĐÃ THIẾT KẾ LẠI) -->
    <div class="featured-products-section bg-white p-4 p-md-5 rounded-4 shadow-sm mb-5 border">

        <!-- Tiêu đề Căn Giữa và Có Thanh Trang Trí -->
        <div class="text-center mb-5">
            <h2 class="text-uppercase fw-bold m-0 animated-gradient-text display-6 mb-3">
                <i class="fas fa-fire text-danger me-2"></i> Xu Hướng Nổi Bật
            </h2>
            <div class="mx-auto mb-3" style="width: 80px; height: 4px; background-color: var(--accent-color); border-radius: 2px;"></div>
        </div>

        <!-- BỌC SẢN PHẨM BẰNG SWIPER -->
        <div class="swiper featured-swiper px-2">
            <div class="swiper-wrapper py-2">

                @* Model.FeaturedProducts là danh sách sản phẩm bạn truyền từ HomeController *@
                @foreach (var item in Model.FeaturedProducts)
                {
                    <div class="swiper-slide h-auto">
                        <!-- Thẻ sản phẩm đã được làm bé lại và tối ưu khoảng trắng -->
                        <div class="card h-100 shadow-sm border-0 rounded-4 product-card-cps position-relative mx-1">

                            <!-- Nhãn HOT -->
                            <span class="badge bg-danger position-absolute" style="top: 10px; left: -5px; z-index: 10; box-shadow: 2px 2px 5px rgba(0,0,0,0.2);">
                                🔥 HOT
                            </span>

                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                <!-- Đã giảm height từ 200px xuống 160px để thẻ lùn lại và gọn gàng hơn -->
                                <img src="@item.ThumbnailUrl" class="card-img-top p-3 rounded-top-4 bg-white" alt="@item.Name" style="height: 160px; object-fit: contain;">
                            </a>
                            <div class="card-body d-flex flex-column text-center pt-0 pb-3 px-3">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                    <h6 class="card-title fw-bold text-truncate-2 mb-2" style="font-size: 0.85rem;">@item.Name</h6>
                                </a>
                                <p class="card-text text-accent fw-bold mt-auto fs-6 mb-0">@item.Price.ToString("N0") ₫</p>
                            </div>
                        </div>
                    </div>
                }

            </div>
            <!-- Dấu chấm phân trang (Pagination Dots) -->
            <div class="swiper-pagination"></div>
        </div>
    </div>

    <!-- KHỐI 2: SẢN PHẨM THEO TỪNG DANH MỤC LỚN -->
    @foreach (var catSection in Model.CategorySections)
    {
        <div class="product-section mb-5">
            <div class="section-title">
                <h2>@catSection.CategoryName</h2>
                <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@catSection.CategoryId" class="view-all-link mb-1">Xem tất cả @catSection.CategoryName »</a>
            </div>

            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var item in catSection.Products)
                {
                    <div class="col">
                        <div class="card h-100 card-product shadow-sm border-0 bg-light">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                <img src="@item.ThumbnailUrl" class="card-img-top p-3 bg-white" alt="@item.Name" style="object-fit: contain; height: 220px;">
                                <div class="card-body pt-2 text-center">
                                    <span class="badge bg-secondary text-white border mb-2">@item.BrandName</span>
                                    @if (!string.IsNullOrEmpty(item.SportName))
                                    {
                                        <span class="badge border border-secondary text-secondary mb-2">@item.SportName</span>
                                    }
                                    <h6 class="card-title text-truncate fw-bold" title="@item.Name">@item.Name</h6>
                                    <p class="card-text text-accent fw-bold fs-5 mb-0">@item.Price.ToString("N0") ₫</p>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        function initSwiper() {
            if (typeof Swiper === 'undefined') {
                console.error("Thư viện Swiper chưa được tải!");
                return;
            }

            var swiper = new Swiper('.featured-swiper', {
                slidesPerView: 2, // Điện thoại: 2 sản phẩm
                spaceBetween: 10,
                autoplay: {
                    delay: 3500, // Tăng nhẹ thời gian trượt lên 3.5s
                    disableOnInteraction: false,
                },
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                breakpoints: {
                    // Cấu hình nhồi nhiều item hơn để thẻ tự động bé lại
                    576: { slidesPerView: 3, spaceBetween: 15 },
                    768: { slidesPerView: 4, spaceBetween: 15 },
                    1024: { slidesPerView: 5, spaceBetween: 20 },
                    1200: { slidesPerView: 6, spaceBetween: 20 } // Màn lớn hiện tới 6 cái
                }
            });
        }

        // Đảm bảo mã chạy hoàn hảo không bị kẹt tiến trình DOM
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initSwiper);
        } else {
            initSwiper();
        }
    </script>
}