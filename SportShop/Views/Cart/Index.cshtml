@model List<SportShop.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    // Tính tổng tiền toàn bộ giỏ
    decimal grandTotal = Model?.Sum(x => x.Total) ?? 0;
}

<div class="container mt-4 mb-5">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold m-0 text-primary-theme"><i class="fas fa-shopping-cart text-accent me-2"></i> GIỎ HÀNG CỦA BẠN</h2>
        @if (Model != null && Model.Any())
        {
            <span class="badge bg-accent ms-3 fs-6 rounded-pill">@Model.Sum(x => x.Quantity) Sản phẩm</span>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center py-5">
                <div class="display-1 text-muted mb-3">🛒</div>
                <h4 class="fw-bold text-dark mb-2">Giỏ hàng của bạn đang trống!</h4>
                <p class="text-muted mb-4">Hãy dạo quanh và tìm cho mình những sản phẩm thể thao ưng ý nhé.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-sport btn-lg px-5 rounded-pill shadow-sm">
                    <i class="fas fa-arrow-left me-2"></i> Tiếp tục mua sắm
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- CỘT TRÁI: DANH SÁCH SẢN PHẨM -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light text-secondary text-uppercase small fw-bold">
                                    <tr>
                                        <th scope="col" class="ps-4 py-3">Sản Phẩm</th>
                                        <th scope="col" class="text-center py-3">Đơn Giá</th>
                                        <th scope="col" class="text-center py-3">Số Lượng</th>
                                        <th scope="col" class="text-center py-3">Thành Tiền</th>
                                        <th scope="col" class="text-center pe-4 py-3">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="flex-shrink-0">
                                                        <img src="@item.ThumbnailUrl" alt="@item.ProductName" class="img-thumbnail rounded" style="width: 80px; height: 80px; object-fit: contain; border-color: #eee;">
                                                    </a>
                                                    <div class="ms-3 min-w-0">
                                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="fw-bold text-dark text-decoration-none d-block mb-1 text-truncate" style="max-width: 250px;">
                                                            @item.ProductName
                                                        </a>
                                                        <div class="d-flex gap-2">
                                                            <span class="badge bg-light text-dark border"><small class="text-muted">Size:</small> @item.Size</span>
                                                            <span class="badge bg-light text-dark border"><small class="text-muted">Màu:</small> @item.Color</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center fw-bold text-dark">@item.Price.ToString("N0") ₫</td>
                                            <td class="text-center" style="width: 140px;">
                                                <!-- Form cập nhật số lượng có nút +/- -->
                                                <form asp-action="UpdateQuantity" method="post" class="d-flex justify-content-center m-0 qty-form">
                                                    <input type="hidden" name="variantId" value="@item.VariantId" />
                                                    <div class="input-group input-group-sm w-auto shadow-sm rounded flex-nowrap">
                                                        <button class="btn btn-outline-secondary btn-minus px-2" type="button">−</button>
                                                        <input type="number" name="newQuantity" class="form-control text-center fw-bold px-1 border-secondary border-opacity-25 qty-input" value="@item.Quantity" min="1" max="50" style="width: 45px; -moz-appearance: textfield;">
                                                        <button class="btn btn-outline-secondary btn-plus px-2" type="button">+</button>
                                                    </div>
                                                </form>
                                            </td>
                                            <td class="text-center fw-bold text-accent">@item.Total.ToString("N0") ₫</td>
                                            <td class="text-center pe-4">
                                                <a asp-action="Remove" asp-route-variantId="@item.VariantId" class="btn btn-sm btn-light text-danger rounded-circle p-2" title="Xóa" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này khỏi giỏ?')" style="width: 35px; height: 35px; line-height: 1;">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted fw-bold hover-accent">
                        <i class="fas fa-arrow-left me-1"></i> Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <!-- CỘT PHẢI: TỔNG TIỀN & THANH TOÁN -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 bg-white sticky-top" style="top: 20px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 text-uppercase border-bottom pb-2">Tóm Tắt Đơn Hàng</h5>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng phụ (<span class="fw-bold text-dark">@Model.Sum(x => x.Quantity)</span> sản phẩm):</span>
                            <span class="fw-bold text-dark">@grandTotal.ToString("N0") ₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Phí vận chuyển:</span>
                            <span class="text-success small fw-bold">Tính ở bước sau</span>
                        </div>

                        <hr class="my-3 border-secondary border-opacity-25">

                        <div class="d-flex justify-content-between align-items-end mb-4">
                            <span class="fw-bold fs-6 text-dark">Tổng CỘNG:</span>
                            <div class="text-end">
                                <span class="fw-bold display-6 text-accent d-block" style="font-size: 1.5rem;">@grandTotal.ToString("N0") ₫</span>
                                <small class="text-muted">(Đã bao gồm VAT nếu có)</small>
                            </div>
                        </div>

                        <a asp-controller="Order" asp-action="Checkout" class="btn btn-sport btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2">
                            <span>Tiến Hành Thanh Toán</span> <i class="fas fa-arrow-right"></i>
                        </a>

                        <div class="mt-4 text-center">
                            <p class="text-muted small mb-2">Chấp nhận thanh toán</p>
                            <div class="d-flex justify-content-center gap-2 text-muted fs-4">
                                <i class="fab fa-cc-visa"></i>
                                <i class="fab fa-cc-mastercard"></i>
                                <i class="fas fa-money-bill-wave"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <!-- Gọi UI xử lý giỏ hàng -->
    <script src="~/js/cart.js" asp-append-version="true"></script>
}