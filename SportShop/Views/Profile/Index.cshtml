@model SportShop.ViewModels.User.UserProfileViewModel
@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <!-- Sidebar Menu -->
        <div class="col-md-3">
            <partial name="_AccountSidebar" />
        </div>

        <!-- Cột Phải: Nội Dung -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold text-primary-theme mb-4 border-bottom pb-3 text-uppercase">Hồ Sơ Của Tôi</h5>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success rounded-3"><i class="fas fa-check-circle me-2"></i> @TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger rounded-3"><i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]</div>
                    }

                    <!-- KHU VỰC BÁO LỖI TỔNG QUÁT: Giúp bạn không bao giờ bị "mù thông tin" khi lưu thất bại -->
                    <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

                    <style>
                        .avatar-upload-container:hover .avatar-overlay {
                            opacity: 1 !important;
                        }
                    </style>

                    <form asp-controller="Profile" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">

                        <!-- Upload Ảnh MỚI -->
                        <div class="row mb-4 align-items-center">
                            <label class="col-sm-3 col-form-label fw-bold text-muted">Ảnh đại diện</label>
                            <div class="col-sm-9">
                                @{
                                    string avatarSrc = !string.IsNullOrEmpty(Model.AvatarUrl)
                                    ? Model.AvatarUrl
                                    : $"https://ui-avatars.com/api/?name={Model.FullName ?? "User"}&background=F1600D&color=fff&rounded=true&bold=true";
                                }

                                <div class="avatar-upload-container position-relative d-inline-block cursor-pointer" onclick="document.getElementById('AvatarFile').click()" style="cursor: pointer;">
                                    <img src="@avatarSrc" id="avatarPreview" alt="Avatar" class="rounded-circle shadow-sm border" width="120" height="120" style="object-fit: cover; transition: all 0.3s;">

                                    <div class="avatar-overlay position-absolute top-0 start-0 w-100 h-100 rounded-circle d-flex flex-column justify-content-center align-items-center text-white text-center p-2" style="background: rgba(0,0,0,0.6); opacity: 0; transition: opacity 0.3s ease;">
                                        <i class="fas fa-camera fs-5 mb-1"></i>
                                        <span class="fw-bold" style="font-size: 0.85rem;">Chọn ảnh mới</span>
                                        <span class="mt-1" style="font-size: 0.65rem; opacity: 0.8;">Hỗ trợ .jpg, .png...<br />(Tối đa 5MB)</span>
                                    </div>
                                </div>

                                <input type="hidden" asp-for="AvatarUrl" />
                                <input asp-for="AvatarFile" type="file" id="AvatarFile" accept="image/jpeg, image/png, image/gif, image/webp" class="d-none" onchange="previewImage(this, 'avatarPreview')" />
                                <span asp-validation-for="AvatarFile" class="text-danger small d-block mt-2"></span>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="row mb-4 align-items-center">
                            <label class="col-sm-3 col-form-label fw-bold text-muted">Email đăng nhập</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control bg-light rounded-3" value="@User.Identity.Name" readonly disabled>
                            </div>
                        </div>

                        <!-- Họ Tên -->
                        <div class="row mb-4 align-items-center">
                            <label class="col-sm-3 col-form-label fw-bold text-muted">Họ và tên</label>
                            <div class="col-sm-9">
                                <input asp-for="FullName" class="form-control rounded-3" placeholder="Nhập họ tên của bạn" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- SĐT -->
                        <div class="row mb-4 align-items-center">
                            <label class="col-sm-3 col-form-label fw-bold text-muted">Số điện thoại</label>
                            <div class="col-sm-9">
                                <input asp-for="PhoneNumber" class="form-control rounded-3" placeholder="Nhập số điện thoại liên hệ" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Ngày sinh -->
                        <div class="row mb-4 align-items-center">
                            <label class="col-sm-3 col-form-label fw-bold text-muted">Ngày sinh</label>
                            <div class="col-sm-9">
                                <input asp-for="DateOfBirth" type="date" class="form-control rounded-3" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Giới tính -->
                        <div class="row mb-5 align-items-center">
                            <label class="col-sm-3 col-form-label fw-bold text-muted">Giới tính</label>
                            <div class="col-sm-9 d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="Gender" value="Nam" id="genderMale">
                                    <label class="form-check-label cursor-pointer" for="genderMale">Nam</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="Gender" value="Nữ" id="genderFemale">
                                    <label class="form-check-label cursor-pointer" for="genderFemale">Nữ</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="Gender" value="Khác" id="genderOther">
                                    <label class="form-check-label cursor-pointer" for="genderOther">Khác</label>
                                </div>
                            </div>
                        </div>

                        <!-- Nút Lưu -->
                        <div class="row">
                            <div class="col-sm-9 offset-sm-3">
                                <button type="submit" class="btn btn-sport px-5 py-2 rounded-pill fw-bold shadow-sm btn-prevent-double">
                                    <i class="fas fa-save me-2"></i> Lưu thay đổi
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}