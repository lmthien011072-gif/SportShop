@using SportShop.ViewModels.Order
@using SportShop.Entities
@model OrderDetailViewModel

@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="container mt-4 mb-5">
    <div class="row">
        <!-- Sidebar Menu -->
        <div class="col-md-3 mb-4">
            <partial name="_AccountSidebar" />
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <a asp-action="History" class="text-decoration-none text-muted fw-bold hover-accent"><i class="fas fa-arrow-left me-1"></i> Quay lại</a>
                <h5 class="fw-bold text-primary-theme m-0">CHI TIẾT ĐƠN HÀNG <span class="text-accent">#@Model.Id</span></h5>
            </div>

            <!-- UX: KHỐI THÔNG BÁO RÕ RÀNG -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4 rounded-3" role="alert">
                    <i class="fas fa-check-circle me-2 fs-5 align-middle"></i>
                    <strong class="align-middle">Thành công!</strong> <span class="align-middle">@TempData["Success"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 border-start border-danger border-4 rounded-3" role="alert">
                    <i class="fas fa-exclamation-triangle me-2 fs-5 align-middle"></i>
                    <strong class="align-middle">Cảnh báo:</strong> <span class="align-middle">@TempData["Error"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Lời nhắc thanh toán -->
            @if (Model.PaymentMethod == PaymentMethod.BankTransfer && Model.PaymentStatus == PaymentStatus.Unpaid && Model.OrderStatus != OrderStatus.Cancelled)
            {
                <div class="alert alert-warning shadow-sm rounded-4 border-warning mb-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                    <div>
                        <h6 class="fw-bold text-dark m-0"><i class="fas fa-exclamation-circle text-warning me-2"></i> Đơn hàng đang chờ thanh toán!</h6>
                        <p class="small text-muted m-0 mt-1">Vui lòng quét mã QR chuyển khoản để chúng tôi có thể xử lý đơn hàng cho bạn.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="QrPayment" asp-route-orderId="@Model.Id" class="btn btn-sport btn-sm rounded-pill px-3 fw-bold btn-prevent-double">
                            <i class="fas fa-qrcode"></i> Thanh toán ngay
                        </a>
                    </div>
                </div>
            }

            <!-- 2 KHỐI THÔNG TIN CHÍNH -->
            <div class="row g-4 mb-4">
                <!-- Khối 1: Thông tin giao hàng -->
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 rounded-4 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold text-secondary text-uppercase mb-4 border-bottom pb-2">Thông tin giao hàng</h6>

                            <h5 class="fw-bold text-dark mb-2" style="font-size: 1.15rem;">
                                @Model.CustomerName <span class="text-muted fw-light mx-1">|</span> <span class="text-secondary" style="font-size: 1.05rem;">@Model.PhoneNumber</span>
                            </h5>

                            <div class="p-2 bg-light rounded border mt-2">
                                @{
                                    var addressParts = Model.ShippingAddress?.Split(',');
                                    if (addressParts != null && addressParts.Length > 0)
                                    {
                                        <div class="fw-bold text-dark mb-1">@addressParts[0].Trim()</div>
                                        @foreach (var part in addressParts.Skip(1))
                                        {
                                            <div class="text-muted small"><i class="fas fa-map-marker-alt me-1 opacity-50"></i>@part.Trim()</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Model.ShippingAddress</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Khối 2: Trạng thái & Tài chính -->
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 rounded-4 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold text-secondary text-uppercase mb-4 border-bottom pb-2">Trạng thái & Thanh toán</h6>

                            <div class="row mb-2">
                                <div class="col-5 text-muted">Loại đơn:</div>
                                <div class="col-7 text-end">
                                    @if (Model.IsCustomized)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="fas fa-cut me-1"></i> Gia Công / Sỉ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">Đơn thường</span>
                                    }
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-5 text-muted">Trạng thái:</div>
                                <div class="col-7 text-end">
                                    <span class="badge @Model.OrderStatusBadgeClass px-2 py-1">@Model.OrderStatusName</span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-5 text-muted">Thanh toán:</div>
                                <div class="col-7 text-end fw-bold text-dark">
                                    <div>@Model.PaymentMethodName</div>
                                    <div class="mt-1"><span class="badge @Model.PaymentStatusBadgeClass">@Model.PaymentStatusName</span></div>
                                </div>
                            </div>

                            <hr class="my-2 border-secondary border-opacity-25" />

                            @if (Model.AdvancePaymentAmount > 0)
                            {
                                <div class="row mb-1 small">
                                    <div class="col-6 text-muted">Cần cọc trước:</div>
                                    <div class="col-6 text-end fw-bold text-primary">@Model.AdvancePaymentAmount.ToString("N0") ₫</div>
                                </div>
                            }
                            <div class="row mb-1 small">
                                <div class="col-6 text-muted">Đã thanh toán:</div>
                                <div class="col-6 text-end fw-bold text-success">@Model.PaidAmount.ToString("N0") ₫</div>
                            </div>
                            <div class="row mb-1 small">
                                <div class="col-6 text-muted">Còn phải thu:</div>
                                <div class="col-6 text-end fw-bold text-danger">@Model.RemainingAmount.ToString("N0") ₫</div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <!-- TÙY CHỌN KHÁCH TỰ HỦY ĐƠN -->
            @if (Model.OrderStatus == OrderStatus.Pending || Model.OrderStatus == OrderStatus.Confirmed)
            {
                <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light border-danger">
                    <div class="card-body p-3 d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold text-danger mb-1"><i class="fas fa-exclamation-triangle me-1"></i> Tùy chọn Hủy Đơn</h6>
                            <span class="small text-muted">Bạn chỉ có thể hủy khi đơn hàng chưa được giao cho Đơn vị vận chuyển.</span>
                        </div>
                        <form asp-action="CancelMyOrder" method="post" onsubmit="return confirmCancelOrder(@Model.IsCustomized.ToString().ToLower(), '@Model.PaymentStatus.ToString()');">
                            <input type="hidden" name="orderId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger fw-bold rounded-pill px-4">Yêu cầu Hủy đơn</button>
                        </form>
                    </div>
                </div>
            }

            <!-- Danh sách sản phẩm -->
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-secondary small text-uppercase">
                            <tr>
                                <th class="py-3 px-4 text-nowrap">Sản Phẩm</th>
                                <th class="py-3 text-center text-nowrap">Đơn Giá</th>
                                <th class="py-3 text-center text-nowrap">SL</th>
                                <th class="py-3 text-end pe-4 text-nowrap">Thành Tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="py-3 px-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@item.ThumbnailUrl" alt="@item.ProductName" class="img-thumbnail rounded-3 border-0 bg-light" style="width: 65px; height: 65px; object-fit: contain;" onerror="this.src='/images/no-image.png'">
                                            <div class="ms-3">
                                                <h6 class="fw-bold text-dark mb-1 text-truncate" style="max-width: 300px;" title="@item.ProductName">@item.ProductName</h6>
                                                <small class="text-muted">Size: <strong class="text-dark">@item.Size</strong> | Màu: <strong class="text-dark">@item.Color</strong></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center fw-medium">@item.Price.ToString("N0") ₫</td>
                                    <td class="text-center"><span class="badge bg-light text-dark border px-3 py-2 rounded-pill">@item.Quantity</span></td>
                                    <td class="text-end fw-bold text-dark pe-4">@item.Total.ToString("N0") ₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light border-top-0 p-4 d-flex justify-content-end align-items-center">
                    <span class="text-uppercase text-muted fw-bold me-3 fs-6">Tổng cộng:</span>
                    <h3 class="fw-bold text-danger m-0 display-6" style="font-size: 1.75rem;">@Model.TotalAmount.ToString("N0") ₫</h3>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmCancelOrder(isCustomized, paymentStatus) {
            let message = "Bạn có chắc chắn muốn HỦY đơn hàng này không?\n\n";

            // Cảnh báo động (UX thông minh)
            if (isCustomized && (paymentStatus === 'Paid' || paymentStatus === 'PartiallyPaid')) {
                message += "⚠️ LƯU Ý QUAN TRỌNG:\nĐây là ĐƠN GIA CÔNG và đã được thanh toán/đặt cọc. Thao tác hủy chủ động từ bạn sẽ dẫn đến việc BỊ TỊCH THU TIỀN CỌC theo chính sách của cửa hàng.";
            } else if (paymentStatus === 'Paid' || paymentStatus === 'PartiallyPaid') {
                message += "Hệ thống sẽ ghi nhận trạng thái chờ Hoàn tiền. Kế toán sẽ liên hệ bạn để thực hiện hoàn tiền trong 24h làm việc.";
            }

            return confirm(message);
        }
    </script>
}