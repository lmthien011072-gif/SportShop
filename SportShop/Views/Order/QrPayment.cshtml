@{
    ViewData["Title"] = "Thanh toán qua mã QR";
    var orderId = ViewBag.OrderId;
    var amountToPay = (decimal)ViewBag.AmountToPay;
    var isPartial = (bool)ViewBag.IsPartial;

    // Tự động sinh nội dung chuyển khoản theo mã đơn
    string transferContent = $"Thanh toan don hang {orderId}";
}

<div class="container mt-5 mb-5 text-center">
    <div class="card shadow-sm border-0 py-5 mx-auto rounded-4" style="max-width: 550px;">
        <div class="card-body">
            <div class="mb-4 d-flex justify-content-center align-items-center">
                <!-- Logo VietQR và Ngân hàng -->
                <img src="https://vietqr.net/portal/v3/images/vietqr.png" alt="VietQR" height="30" class="me-3" />
                <span class="fs-4 fw-bold text-muted mx-2">|</span>
                <!-- Logo VietinBank -->
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/22/VietinBank_logo.svg/2560px-VietinBank_logo.svg.png" alt="VietinBank" height="30" class="ms-2" />
            </div>

            <!-- TIÊU ĐỀ ĐỘNG DỰA TRÊN LOẠI THANH TOÁN -->
            @if (isPartial)
            {
                <h4 class="fw-bold text-warning mb-2"><i class="fas fa-hand-holding-usd me-2"></i> ĐẶT CỌC ĐƠN HÀNG</h4>
                <p class="text-muted mb-4 px-3">Sử dụng ứng dụng Ngân hàng quét mã QR để <strong class="text-danger">thanh toán cọc 30%</strong> cho đơn hàng <strong>#@orderId</strong>.</p>
            }
            else
            {
                <h4 class="fw-bold text-primary-theme mb-2">QUÉT MÃ ĐỂ THANH TOÁN</h4>
                <p class="text-muted mb-4 px-3">Sử dụng ứng dụng Ngân hàng (SmartBanking) hỗ trợ quét mã VietQR để thanh toán 100% cho đơn hàng <strong>#@orderId</strong>.</p>
            }

            <!-- Vùng hiển thị mã QR (Sử dụng API VietQR chuẩn với thông tin của bạn) -->
            <div class="bg-light p-3 rounded-4 mb-4 d-inline-block border shadow-sm">
                <!-- Mã BIN 970415 là của VietinBank. amount=amountToPay được truyền động -->
                <img src="https://img.vietqr.io/image/970415-0333069427-compact2.png?amount=@amountToPay&addInfo=@transferContent&accountName=LU MINH THIEN"
                     alt="Mã QR Thanh Toán Đơn Hàng" class="img-fluid rounded-3 bg-white border p-2" style="width: 250px; height: 250px;" />
            </div>

            <div class="text-start bg-light p-4 rounded-4 mx-auto border" style="max-width: 400px;">
                <p class="mb-2 d-flex justify-content-between"><span class="text-muted">Chủ tài khoản:</span> <strong class="text-dark">LU MINH THIEN</strong></p>
                <p class="mb-2 d-flex justify-content-between"><span class="text-muted">Số tài khoản:</span> <strong class="text-dark">0333069427</strong></p>
                <p class="mb-2 d-flex justify-content-between"><span class="text-muted">Ngân hàng:</span> <strong class="text-dark">VietinBank</strong></p>

                <hr class="border-secondary border-opacity-25 my-3" />

                <p class="mb-2 d-flex justify-content-between align-items-center">
                    <span class="text-muted">Số tiền @(isPartial ? "cần cọc" : "thanh toán"):</span>
                    <span class="text-accent fw-bold fs-4">@amountToPay.ToString("N0") ₫</span>
                </p>
                <p class="mb-0 d-flex justify-content-between align-items-center mt-2">
                    <span class="text-muted">Nội dung CK:</span>
                    <strong class="text-primary-theme fs-6 bg-white border px-2 py-1 rounded">@transferContent</strong>
                </p>
            </div>

            <div class="alert alert-warning mt-4 text-start small border-warning bg-white shadow-sm rounded-3">
                <i class="fas fa-exclamation-triangle text-warning me-2"></i><i class="fw-bold">Lưu ý quan trọng:</i>
                Vui lòng điền <strong>chính xác Số tiền</strong> và <strong>Nội dung chuyển khoản</strong> để hệ thống đối soát tự động nhanh nhất.
            </div>

            <div class="mt-4">
                <a asp-action="Success" asp-route-orderId="@orderId" class="btn btn-sport btn-lg px-5 fw-bold shadow-sm rounded-pill">
                    <i class="fas fa-check-circle me-2"></i> Tôi đã chuyển khoản xong
                </a>
                <div class="mt-3">
                    <a asp-action="Details" asp-route-id="@orderId" class="text-muted text-decoration-none small hover-accent">Xem chi tiết đơn hàng</a>
                </div>
            </div>
        </div>
    </div>
</div>