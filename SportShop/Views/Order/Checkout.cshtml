@using SportShop.ViewModels.Order
@model CheckoutViewModel

@{
    ViewData["Title"] = "Thực hiện thanh toán đơn hàng";
}

<div class="container mt-4 mb-5">
    <h2 class="fw-bold mb-4 text-primary-theme">THÔNG TIN THANH TOÁN</h2>

    <form asp-controller="Order" asp-action="Checkout" method="post" id="checkoutForm">

        <!-- UX: KHỐI THÔNG BÁO LỖI THÂN THIỆN -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger rounded-3 shadow-sm mb-4 border-0 border-start border-danger border-4">
                <h6 class="fw-bold"><i class="fas fa-exclamation-circle me-2"></i> Rất tiếc, hệ thống ghi nhận một số vấn đề:</h6>
                <div asp-validation-summary="All" class="mb-0 small"></div>
            </div>
        }

        <div class="row g-4">
            <!-- CỘT TRÁI: THÔNG TIN NHẬN HÀNG & PHƯƠNG THỨC THANH TOÁN -->
            <div class="col-lg-7">

                <!-- KHỐI ĐỊA CHỈ NHẬN HÀNG -->
                <div class="card checkout-card shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2 text-uppercase"><i class="fas fa-map-marker-alt text-accent me-2"></i> Địa chỉ giao hàng</h5>

                        @if (Model.SavedAddresses.Any())
                        {
                            <div class="d-flex gap-4 mb-4 border-bottom pb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="AddressType" value="SAVED" id="addressTypeSaved">
                                    <label class="form-check-label fw-bold cursor-pointer" for="addressTypeSaved">Sử dụng địa chỉ đã lưu</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="AddressType" value="NEW" id="addressTypeNew">
                                    <label class="form-check-label fw-bold cursor-pointer" for="addressTypeNew">Giao đến địa chỉ mới</label>
                                </div>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="AddressType" value="NEW" id="addressTypeNew" />
                        }

                        <!-- KHU VỰC 1: ĐỊA CHỈ ĐÃ LƯU -->
                        @if (Model.SavedAddresses.Any())
                        {
                            <div id="savedAddressesArea" class="mb-3">
                                @foreach (var addr in Model.SavedAddresses)
                                {
                                    <label class="d-block position-relative w-100 cursor-pointer m-0 mb-2">
                                        <input type="radio" name="SelectedAddressId" value="@addr.Id" class="address-radio-input d-none" @(Model.SelectedAddressId == addr.Id ? "checked" : "") />
                                        <div class="address-box-content">
                                            <div class="address-item-box">
                                                <h6 class="fw-bold mb-1 text-dark">
                                                    @addr.ReceiverName <span class="text-muted fw-normal">| @addr.PhoneNumber</span>
                                                </h6>
                                                <p class="text-muted mb-0 small">@addr.SpecificAddress</p>
                                                <p class="text-muted mb-0 small">@addr.Commune, @addr.Province</p>
                                                @if (addr.IsDefault)
                                                {
                                                    <span class="badge bg-danger position-absolute top-0 end-0 m-2">Mặc định</span>
                                                }
                                            </div>
                                        </div>
                                    </label>
                                }
                            </div>
                        }

                        <!-- KHU VỰC 2: NHẬP ĐỊA CHỈ MỚI -->
                        <div id="newAddressFormArea" class="@(Model.SavedAddresses.Any() ? "new-address-panel" : "")" style="display: none;">
                            <h6 class="fw-bold text-secondary mb-3 text-uppercase">Nhập thông tin giao hàng mới</h6>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Tên người nhận</label>
                                    <input asp-for="NewAddress.ReceiverName" class="form-control" placeholder="Họ và tên" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Số điện thoại liên hệ</label>
                                    <input asp-for="NewAddress.PhoneNumber" class="form-control" placeholder="Số điện thoại di động" />
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Tỉnh / Thành phố</label>
                                    <select asp-for="NewAddress.Province" class="form-select" id="provinceSelect">
                                        <option value="">-- Đang tải danh sách... --</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Quận/Huyện, Xã/Phường</label>
                                    <select asp-for="NewAddress.Commune" class="form-select" id="communeSelect" disabled>
                                        <option value="">-- Vui lòng chọn Tỉnh/Thành trước --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-2">
                                <label class="form-label small fw-bold">Địa chỉ chi tiết</label>
                                <textarea asp-for="NewAddress.SpecificAddress" class="form-control" rows="2" placeholder="Số nhà, tên đường, ngõ hẻm..."></textarea>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- TÙY CHỌN ĐƠN HÀNG ĐẶC BIỆT (GIA CÔNG) -->
                <div class="card checkout-card shadow-sm mb-4 bg-light border-warning">
                    <div class="card-body p-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input fs-5 cursor-pointer" type="checkbox" asp-for="IsCustomized" id="chkCustomized">
                            <label class="form-check-label fw-bold ms-2 text-dark mt-1 cursor-pointer" for="chkCustomized">
                                Đây là đơn hàng Yêu cầu Gia công / In tên / Mua sỉ
                            </label>
                            <p class="small text-muted mb-0 ms-2 mt-1"><i class="fas fa-info-circle text-warning"></i> Lưu ý: Đơn hàng gia công bắt buộc phải thanh toán trước hoặc đặt cọc 30%. Không hỗ trợ thanh toán COD.</p>
                        </div>
                    </div>
                </div>

                <!-- PHƯƠNG THỨC THANH TOÁN -->
                <div class="card checkout-card shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2 text-uppercase"><i class="fas fa-credit-card text-accent me-2"></i> Phương thức thanh toán</h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="d-block w-100 cursor-pointer m-0" id="lblCod">
                                    <!-- SỬ DỤNG ENUM TRỰC TIẾP -->
                                    <input type="radio" asp-for="PaymentMethod" value="@SportShop.Entities.PaymentMethod.COD" class="payment-radio-input d-none" id="payCOD" />
                                    <div class="payment-method-card text-center h-100">
                                        <div class="fs-2 mb-1">💵</div>
                                        <div class="fw-bold">Thanh toán khi nhận hàng (COD)</div>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-6">
                                <label class="d-block w-100 cursor-pointer m-0">
                                    <!-- SỬ DỤNG ENUM TRỰC TIẾP -->
                                    <input type="radio" asp-for="PaymentMethod" value="@SportShop.Entities.PaymentMethod.BankTransfer" class="payment-radio-input d-none" id="payBank" />
                                    <div class="payment-method-card text-center h-100">
                                        <div class="fs-2 mb-1">🏦</div>
                                        <div class="fw-bold">Chuyển khoản / Quét mã QR</div>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <!-- TÙY CHỌN ĐẶT CỌC -->
                        <div id="partialPaymentSection" class="mt-4 p-3 bg-white rounded-3 border border-primary shadow-sm" style="display: none;">
                            <h6 class="fw-bold text-primary mb-3"><i class="fas fa-hand-holding-usd text-warning me-1"></i> Tùy chọn mức thanh toán:</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" asp-for="IsPartialPayment" value="false" id="payFull" checked>
                                <label class="form-check-label cursor-pointer text-dark" for="payFull">
                                    Thanh toán toàn bộ <strong>100%</strong> (<span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") đ</span>)
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="IsPartialPayment" value="true" id="payPartial">
                                <label class="form-check-label cursor-pointer text-dark" for="payPartial">
                                    Đặt cọc trước <strong>30%</strong> (<span id="depositDisplay" class="text-danger fw-bold">...</span> đ)
                                </label>
                                <div class="text-muted small mt-1">Phần tiền còn lại sẽ thanh toán cho Shipper khi bạn nhận hàng.</div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <!-- CỘT PHẢI: TÓM TẮT ĐƠN HÀNG -->
            <div class="col-lg-5">
                <div class="card checkout-card shadow-sm sticky-top" style="top: 20px; z-index: 10;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2 text-uppercase">Tóm tắt đơn hàng</h5>

                        <div class="checkout-summary-list overflow-auto pe-1" style="max-height: 320px;">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="order-summary-item">
                                    <img src="@item.ThumbnailUrl" alt="@item.ProductName" class="order-summary-img flex-shrink-0" onerror="this.src='/images/no-image.png'" />
                                    <div class="flex-grow-1 min-w-0">
                                        <h6 class="fw-bold text-dark text-truncate mb-1" style="font-size: 0.9rem;">@item.ProductName</h6>
                                        <div class="text-muted small d-flex gap-3">
                                            <span>Size: <strong class="text-dark">@item.Size</strong></span>
                                            <span>Màu: <strong class="text-dark">@item.Color</strong></span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="small text-secondary">SL: x @item.Quantity</span>
                                            <span class="fw-bold text-accent">@item.Total.ToString("N0") ₫</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top mb-4">
                            <h5 class="fw-bold m-0 text-dark">Tổng cộng:</h5>
                            <h4 class="fw-bold m-0 text-danger display-6" style="font-size: 1.6rem;">@Model.TotalAmount.ToString("N0") ₫</h4>
                        </div>

                        <button type="submit" class="btn btn-sport btn-lg w-100 py-3 text-uppercase fw-bold shadow-sm btn-prevent-double" style="font-size: 1.1rem;">
                            🔒 Xác nhận đặt hàng
                        </button>
                        <p class="text-center text-muted small mt-3 mb-0">
                            <i class="fas fa-shield-alt"></i> Thông tin giao dịch của bạn luôn được bảo mật mã hóa
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        <script src="~/js/address-api.js" asp-append-version="true"></script>
        <script src="~/js/checkout.js" asp-append-version="true"></script>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                initPaymentLogic(@Model.TotalAmount);
            });
        </script>
    }
}