@model SportShop.Areas.Admin.ViewModels.Product.ProductAdminViewModel
@{
    ViewData["Title"] = "Thêm Sản phẩm mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row g-4">
        <!-- CỘT TRÁI: THÔNG TIN CƠ BẢN -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-info-circle me-2 text-primary"></i>Thông tin cơ bản</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="CategoryId" class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select" required>
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BrandId" class="form-label fw-bold">Thương hiệu <span class="text-danger">*</span></label>
                            <select asp-for="BrandId" asp-items="Model.Brands" class="form-select" required>
                                <option value="">-- Chọn thương hiệu --</option>
                            </select>
                            <span asp-validation-for="BrandId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SportId" class="form-label fw-bold">Môn thể thao <span class="text-danger">*</span></label>
                            <select asp-for="SportId" asp-items="Model.Sports" class="form-select" required>
                                <option value="">-- Chọn môn thể thao --</option>
                            </select>
                            <span asp-validation-for="SportId" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- ĐÃ THÊM DẤU * VÀ THUỘC TÍNH REQUIRED CHO MÔ TẢ -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả sản phẩm <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết sản phẩm..." required></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- QUẢN LÝ BIẾN THỂ (VARIANTS) -->
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-tags me-2 text-warning"></i>Phân loại hàng (Biến thể)</h6>
                    <button type="button" class="btn btn-sm btn-outline-warning text-dark fw-bold" onclick="addVariantRow()">
                        <i class="fas fa-plus"></i> Thêm phân loại
                    </button>
                </div>
                <div class="card-body p-4" id="variants-container">
                    <!-- ĐÃ THÊM DẤU * VÀO TIÊU ĐỀ CÁC CỘT -->
                    <div class="row fw-bold mb-2 text-muted px-2">
                        <div class="col-4">Màu sắc <span class="text-danger">*</span></div>
                        <div class="col-4">Kích thước (Size) <span class="text-danger">*</span></div>
                        <div class="col-3">Số lượng tồn <span class="text-danger">*</span></div>
                        <div class="col-1"></div>
                    </div>

                    <!-- Khởi tạo sẵn dòng đầu tiên (Index 0) -->
                    <div class="row mb-3 variant-row align-items-center bg-light p-2 rounded mx-0">
                        <div class="col-4">
                            <input type="text" name="Variants[0].Color" class="form-control" placeholder="VD: Đỏ, Xanh..." required />
                        </div>
                        <div class="col-4">
                            <input type="text" name="Variants[0].Size" class="form-control" placeholder="VD: M, L, XL, 42..." required />
                        </div>
                        <div class="col-3">
                            <input type="number" name="Variants[0].StockQuantity" class="form-control" placeholder="0" min="0" required />
                        </div>
                        <div class="col-1 text-end">
                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeVariantRow(this)" disabled><i class="fas fa-times"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: GIÁ & HÌNH ẢNH -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <!-- ĐÃ THÊM DẤU * CHO GIÁ BÁN -->
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-money-bill-wave me-2 text-success"></i>Giá bán <span class="text-danger">*</span></h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-0">
                        <div class="input-group">
                            <!-- Ô NÀY ĐỂ HIỂN THỊ (CÓ DẤU PHẨY) -->
                            <input type="text" id="priceDisplay" class="form-control form-control-lg text-danger fw-bold" placeholder="0" required />

                            <!-- Ô NÀY ĐỂ ẨN (LƯU SỐ NGUYÊN THỦY GỬI LÊN SERVER) -->
                            <input type="hidden" asp-for="Price" />

                            <span class="input-group-text">VNĐ</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-images me-2 text-info"></i>Hình ảnh</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label asp-for="ThumbnailFile" class="form-label fw-bold">Ảnh đại diện (Thumbnail) <span class="text-danger">*</span></label>
                        <input asp-for="ThumbnailFile" type="file" class="form-control" accept="image/*" required />
                        <small class="text-muted d-block mt-1">Ảnh chính hiển thị ngoài danh sách sản phẩm.</small>
                    </div>

                    <hr />

                    <!-- KHÔNG THÊM DẤU * CHO GALLERY THEO YÊU CẦU -->
                    <div class="mb-3">
                        <label asp-for="GalleryFiles" class="form-label fw-bold">Bộ sưu tập ảnh (Gallery)</label>
                        <input asp-for="GalleryFiles" type="file" class="form-control" accept="image/*" multiple />
                        <small class="text-muted d-block mt-1">Có thể chọn nhiều ảnh cùng lúc. Ảnh sẽ hiển thị trong trang chi tiết sản phẩm.</small>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm"><i class="fas fa-save me-2"></i> Lưu Sản Phẩm</button>
                <a asp-action="Index" class="btn btn-light fw-bold">Hủy bỏ</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <!-- Partial Scripts để bật Client-side Validation (Kiểm tra lỗi ở phía trình duyệt) -->
    <partial name="_ValidationScriptsPartial" />

    <!-- Gọi Script xử lý riêng cho trang thêm sản phẩm -->
    <script src="~/js/admin-product-create.js" asp-append-version="true"></script>
}