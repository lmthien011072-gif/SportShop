@model IEnumerable<SportShop.Areas.Admin.ViewModels.User.UserAdminViewModel>
@using SportShop.Entities @* Nhúng Enum vào View *@
@{
    ViewData["Title"] = "Quản lý Khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-users me-2 text-primary"></i>Danh sách Tài khoản</h5>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Khách hàng</th>
                        <th>Liên hệ</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold">#@user.Id</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center fw-bold me-3 shadow-sm" style="width: 40px; height: 40px;">
                                            @(string.IsNullOrEmpty(user.FullName) ? "U" : user.FullName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold text-dark">@user.FullName</h6>
                                            <small class="text-muted">@user.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-dark"><i class="fas fa-phone-alt text-muted small me-1"></i> @user.PhoneNumber</span>
                                </td>
                                <td>
                                    <!-- Sử dụng Enum thay vì String -->
                                    @if (user.Role == UserRole.Admin)
                                    {
                                        <span class="badge bg-danger px-2 py-1"><i class="fas fa-user-shield me-1"></i> Quản trị viên</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-2 py-1"><i class="fas fa-user me-1"></i> Khách hàng</span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsLockedOut)
                                    {
                                        <span class="badge bg-warning text-dark px-2 py-1"><i class="fas fa-lock me-1"></i> Đã bị khóa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success px-2 py-1"><i class="fas fa-check-circle me-1"></i> Đang hoạt động</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <!-- Kiểm tra nút bấm bằng Enum -->
                                    @if (user.Role != UserRole.Admin)
                                    {
                                        <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('@(user.IsLockedOut ? "Bạn muốn mở khóa cho tài khoản này?" : "Bạn có chắc chắn muốn khóa tài khoản này không?")');">
                                            @if (user.IsLockedOut)
                                            {
                                                <button type="submit" class="btn btn-outline-success btn-sm rounded-pill px-3">
                                                    <i class="fas fa-unlock"></i> Mở khóa
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                                    <i class="fas fa-lock"></i> Khóa tài khoản
                                                </button>
                                            }
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-light btn-sm rounded-pill px-3 text-muted" disabled title="Không thể khóa Quản trị viên">
                                            <i class="fas fa-shield-alt"></i> Hệ thống
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Chưa có dữ liệu người dùng.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>