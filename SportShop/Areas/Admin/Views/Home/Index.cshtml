@model SportShop.Areas.Admin.ViewModels.Dashboard.AdminDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan hệ thống";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- KHU VỰC THỐNG KÊ (CARDS) -->
<div class="row g-4 mb-4">
    <!-- Card 1: Đơn hàng mới -->
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow-sm border-0 rounded-4 h-100 card-stat">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase fw-bold opacity-75 mb-2">Đơn hàng mới</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalNewOrders</h2>
                    <small class="opacity-75">Đang chờ xác nhận</small>
                </div>
                <div class="fs-1 opacity-50"><i class="fas fa-shopping-bag"></i></div>
            </div>
        </div>
    </div>

    <!-- Card 2: Doanh thu -->
    <div class="col-md-3">
        <div class="card bg-success text-white shadow-sm border-0 rounded-4 h-100 card-stat">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase fw-bold opacity-75 mb-2">Tổng doanh thu</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalRevenue.ToString("N0") ₫</h2>
                    <small class="opacity-75">Đã thanh toán thành công</small>
                </div>
                <div class="fs-1 opacity-50"><i class="fas fa-chart-line"></i></div>
            </div>
        </div>
    </div>

    <!-- Card 3: Sản phẩm -->
    <div class="col-md-3">
        <div class="card bg-warning text-dark shadow-sm border-0 rounded-4 h-100 card-stat">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase fw-bold opacity-75 mb-2">Tổng sản phẩm</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalProducts.ToString("N0")</h2>
                    <small class="opacity-75">Sản phẩm trong kho</small>
                </div>
                <div class="fs-1 opacity-50"><i class="fas fa-box-open"></i></div>
            </div>
        </div>
    </div>

    <!-- Card 4: Khách hàng -->
    <div class="col-md-3">
        <div class="card bg-danger text-white shadow-sm border-0 rounded-4 h-100 card-stat">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase fw-bold opacity-75 mb-2">Tổng khách hàng</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalCustomers.ToString("N0")</h2>
                    <small class="opacity-75">Tài khoản đã đăng ký</small>
                </div>
                <div class="fs-1 opacity-50"><i class="fas fa-users"></i></div>
            </div>
        </div>
    </div>
</div>

<!-- KHU VỰC THÔNG BÁO CHÀO MỪNG / HƯỚNG DẪN -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-5 text-center py-5">
                <img src="https://cdni.iconscout.com/illustration/premium/thumb/dashboard-ui-4439063-3728469.png" alt="Welcome to Dashboard" style="max-height: 250px; opacity: 0.9" class="mb-4">
                <h4 class="fw-bold text-dark mb-3">Chào mừng bạn trở lại Trung tâm Quản trị SportShop!</h4>
                <p class="text-muted mb-4 fs-5">Mọi thứ đã sẵn sàng. Hãy sử dụng thanh điều hướng bên trái để quản lý cửa hàng của bạn.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Order" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
                        <i class="fas fa-tasks me-2"></i> Xử lý đơn hàng ngay
                    </a>
                    <a asp-controller="Product" asp-action="Create" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold">
                        <i class="fas fa-plus me-2"></i> Thêm sản phẩm mới
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>