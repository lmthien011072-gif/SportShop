@model IEnumerable<SportShop.Areas.Admin.ViewModels.Catalog.SportAdminViewModel>
@{
    ViewData["Title"] = "Quản lý Môn thể thao";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-running me-2 text-warning"></i>Danh sách Môn thể thao</h5>
        <button type="button" class="btn btn-warning text-dark fw-bold btn-sm rounded-pill px-3" onclick="openSportModal(0, '')">
            <i class="fas fa-plus me-1"></i> Thêm Môn thể thao
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width: 100px;">ID</th>
                        <th>Tên Môn thể thao</th>
                        <th class="text-end pe-4" style="width: 200px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@item.Id</td>
                            <td class="fw-bold">@item.Name</td>
                            <td class="text-end pe-4 action-btns">
                                <button class="btn btn-outline-primary btn-sm" onclick="openSportModal(@item.Id, '@item.Name')">
                                    <i class="fas fa-edit"></i> Sửa
                                </button>
                                <form asp-action="DeleteSport" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirmDelete('Bạn có chắc chắn muốn xóa môn @item.Name?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="fas fa-trash-alt"></i> Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Thêm/Sửa Môn thể thao -->
<div class="modal fade" id="sportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold" id="sportModalTitle">Thêm Môn thể thao</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SaveSport" method="post">
                <div class="modal-body">
                    <input type="hidden" id="SportId" name="Id" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên Môn thể thao <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="SportName" name="Name" required placeholder="Ví dụ: Bóng đá, Cầu lông..." />
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning fw-bold text-dark"><i class="fas fa-save me-1"></i> Lưu lại</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openSportModal(id, name) {
            document.getElementById('SportId').value = id;
            document.getElementById('SportName').value = name;
            document.getElementById('sportModalTitle').innerText = id === 0 ? 'Thêm Môn thể thao mới' : 'Cập nhật Môn thể thao';
            var myModal = new bootstrap.Modal(document.getElementById('sportModal'));
            myModal.show();
        }
    </script>
}